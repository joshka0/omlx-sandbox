# Runtime defaults for the oMLX sandbox harness.
#
# Copy to config/runtime.env.local if you want machine-local overrides.
# Do not commit runtime.env.local if it contains secrets.

OMLX_SERVICE_USER=omlxsvc
OMLX_SERVICE_GROUP=_omlxsvc
OMLX_VERSION=v0.3.8
OMLX_BASE=/Users/Shared/omlx-sandbox
OMLX_HOST=127.0.0.1
OMLX_PORT=18000
OMLX_MAX_PROCESS_MEMORY=70%
OMLX_MAX_MODEL_MEMORY=48GB
OMLX_MAX_CONCURRENT_REQUESTS=2
OMLX_RUNTIME=source
OMLX_LAUNCHD_LABEL=com.local.omlx-sandbox
OMLX_START_TIMEOUT_SECONDS=120

# The run script creates OMLX_API_KEY_FILE if it does not exist.
OMLX_API_KEY_FILE=/Users/Shared/omlx-sandbox/state/api-key

# Optional. If unset, the DMG installer auto-detects the newest
# ~/Downloads/oMLX-*.dmg for the sudo-invoking user.
# OMLX_DMG_PATH=/path/to/oMLX.dmg
